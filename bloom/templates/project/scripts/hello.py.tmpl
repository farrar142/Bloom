"""Example scripts - Hello World

사용법:
    bloom run hello
    bloom run hello --name Alice
    bloom run hello -n Bob --greeting "Good morning"

    bloom run seed-data
    bloom run seed-data --count 50 --dry-run
"""

import click

from bloom.scripts import script, BaseScript


# =============================================================================
# 함수 기반 스크립트 (간단한 작업에 적합)
# =============================================================================


@script
@click.option("--name", "-n", default="World", help="인사할 대상")
@click.option("--greeting", "-g", default="Hello", help="인사말")
def hello(name: str, greeting: str, app):
    """Hello World 스크립트

    간단한 인사 메시지를 출력합니다.
    """
    click.secho(f"{greeting}, {name}!", fg="green")

    # DI 컨테이너 사용 예시 (주석 처리)
    # if app:
    #     service = app.manager.get_instance(MyService)
    #     service.do_something()


# =============================================================================
# 클래스 기반 스크립트 (DI 주입이 필요한 복잡한 작업에 적합)
# =============================================================================


@script
class SeedDataScript(BaseScript):
    """테스트 데이터 시딩 스크립트

    데이터베이스에 테스트용 샘플 데이터를 생성합니다.
    DI 컨테이너로부터 Repository를 주입받아 사용합니다.

    사용법:
        bloom run seed-data
        bloom run seed-data --count 50
        bloom run seed-data --dry-run
    """

    # DI 필드 주입 예시 (실제 사용 시 주석 해제)
    # user_repo: UserRepository
    # session: Session

    @click.option("--count", "-c", type=int, default=10, help="생성할 데이터 수")
    @click.option("--dry-run", is_flag=True, help="실제 생성 없이 시뮬레이션만")
    def handle(self, count: int, dry_run: bool):
        """스크립트 실행 로직"""
        if dry_run:
            click.secho(f"[DRY RUN] Would create {count} records", fg="yellow")
            return

        click.echo(f"Creating {count} records...")

        for i in range(count):
            # 실제 사용 시: self.user_repo.save(User(name=f"User {i}"))
            click.echo(f"  Created record {i + 1}/{count}")

        click.secho(f"✓ Successfully created {count} records", fg="green")

