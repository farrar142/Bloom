"""{{project_name}} Application

Bloom Framework 기반 애플리케이션입니다.

실행 방법:
    # 개발 서버
    uvicorn application:application.asgi --reload

    # 워커
    bloom worker

    # 마이그레이션
    bloom db makemigrations
    bloom db migrate
"""

from bloom import Application

from settings import configure


# =============================================================================
# Application 인스턴스
# =============================================================================

application = Application("{{project_name}}")

# 설정 모듈 스캔 + 현재 디렉토리 자동 스캔
# ASGI 실행 시 lifespan.startup에서 자동으로 초기화됩니다
application.scan(configure).auto_import(exclude={"application.py"})
