"""Middleware & Advice Configuration

MiddlewareChainкіј MethodAdviceRegistry м„Өм •мһ…лӢҲлӢӨ.
CORSмҷҖ ErrorHandler лҜёл“ӨмӣЁм–ҙлҠ” кё°ліё л“ұлЎқлҗҳм–ҙ мһҲмҠөлӢҲлӢӨ.
"""

from bloom import Component
from bloom.core.decorators import Factory
from bloom.core.advice import MethodAdvice, MethodAdviceRegistry
from bloom.web.middleware import Middleware, MiddlewareChain


# =============================================================================
# MiddlewareChain
# =============================================================================

@Component
class MiddlewareConfig:
    """лҜёл“ӨмӣЁм–ҙ м„Өм • м»ҙнҸ¬л„ҢнҠё
    
    CORSмҷҖ ErrorHandlerлҠ” кё°ліё л“ұлЎқлҗҳм–ҙ мһҲмҠөлӢҲлӢӨ.
    м¶”к°Җ лҜёл“ӨмӣЁм–ҙк°Җ н•„мҡ”н•ҳл©ҙ MiddlewareлҘј мғҒмҶҚн•ң @ComponentлҘј л§Ңл“Өл©ҙ лҗ©лӢҲлӢӨ.
    """

    @Factory
    def middleware_chain(self, *middlewares: Middleware) -> MiddlewareChain:
        """MiddlewareChainмқ„ мғқм„ұн•©лӢҲлӢӨ.
        
        Args:
            *middlewares: DIлЎң мЈјмһ…лҗң лӘЁл“  Middleware мқёмҠӨн„ҙмҠӨ
            
        Returns:
            MiddlewareChain: лҜёл“ӨмӣЁм–ҙ мІҙмқё
        """
        chain = MiddlewareChain()
        chain.add_group_after(*middlewares)
        return chain


# =============================================================================
# MethodAdviceRegistry
# =============================================================================

@Component
class AdviceConfig:
    """Advice м„Өм • м»ҙнҸ¬л„ҢнҠё
    
    MethodAdviceRegistryлҠ” кё°ліём ҒмңјлЎң CallStackTraceAdviceлҘј нҸ¬н•Ён•©лӢҲлӢӨ.
    м¶”к°Җ Adviceк°Җ н•„мҡ”н•ҳл©ҙ *advices нҢҢлқјлҜён„°лЎң мЈјмһ…л°ӣм•„ л“ұлЎқн•©лӢҲлӢӨ.
    """

    @Factory
    def advice_registry(self, *advices: MethodAdvice) -> MethodAdviceRegistry:
        """MethodAdviceRegistryлҘј мғқм„ұн•©лӢҲлӢӨ.
        
        Args:
            *advices: DIлЎң мЈјмһ…лҗң лӘЁл“  MethodAdvice мқёмҠӨн„ҙмҠӨ
            
        Returns:
            MethodAdviceRegistry: м–ҙл“ңл°”мқҙмҠӨ л Ҳм§ҖмҠӨнҠёлҰ¬
        """
        registry = MethodAdviceRegistry()  # кё°ліё CallStackTraceAdvice нҸ¬н•Ё
        
        for advice in advices:
            registry.register(advice)
        
        return registry
