"""Task Configuration

백그라운드 태스크 설정입니다.
"""

from bloom import Component, Lazy, PostConstruct, PreDestroy
from bloom.core.decorators import Factory
from bloom.task import TaskBackend, DistributedTaskBackend, InMemoryBroker


# =============================================================================
# TaskRegistry & TaskBackend
# =============================================================================


@Component
class TaskConfig:
    """태스크 설정 컴포넌트

    @Factory로 TaskBackend를 생성하고,
    Lazy[TaskBackend]로 지연 주입받아 사용합니다.
    """

    backend: Lazy[TaskBackend]  # @Factory의 결과가 자동 주입됨

    @Factory
    def task_backend(self) -> TaskBackend:
        """TaskBackend를 생성합니다.

        REDIS_URL이 설정된 경우 DistributedTaskBackend를,
        그렇지 않으면 InMemoryBroker를 사용합니다.

        Returns:
            TaskBackend: 태스크 백엔드
        """
        return DistributedTaskBackend(InMemoryBroker())

    @PostConstruct
    async def start_backend(self):
        """백엔드 시작"""
        await self.backend.start()

    @PreDestroy
    async def stop_backend(self):
        """백엔드 종료"""
        await self.backend.shutdown()

