"""Database Configuration

데이터베이스 연결 설정입니다.
bloom.db 모듈을 사용하여 ORM 기능을 제공합니다.
"""

import os

from bloom import Component
from bloom.core import ScopeEnum, PrototypeMode
from bloom.core.decorators import Factory, Scope
from bloom.db import AsyncSession, SessionFactory
from bloom.db.backends import get_backend

# =============================================================================
# Database Settings
# =============================================================================

DATABASE_URL = os.getenv("DATABASE_URL", "sqlite:///db.sqlite3")


# =============================================================================
# Database Configuration
# =============================================================================


@Component
class DatabaseConfig:
    """데이터베이스 설정 컴포넌트"""

    @Factory
    def session_factory(self) -> SessionFactory:
        """SessionFactory를 DI 컨테이너에 등록"""
        backend = get_backend(DATABASE_URL)
        return SessionFactory(backend)

    @Factory
    @Scope(ScopeEnum.CALL, mode=PrototypeMode.CALL_SCOPED)
    async def session(self, session_factory: SessionFactory) -> AsyncSession:
        """비동기 세션 - CALL 스코프 + CALL_SCOPED로 핸들러 내 동일 세션 공유

        Usage:
            @Component
            class UserRepository:
                session: AsyncSession  # 요청 내 동일 세션 주입

                async def find_by_id(self, user_id: int) -> User | None:
                    return await self.session.get(User, user_id)

                async def save(self, user: User) -> User:
                    self.session.add(user)
                    await self.session.commit()
                    return user
        """
        return await session_factory.create_async()

