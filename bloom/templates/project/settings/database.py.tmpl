"""Database Configuration

데이터베이스 연결 및 세션 팩토리 설정입니다.
"""

import os

from bloom import Component
from bloom.core.decorators import Factory
from bloom.db import SessionFactory


# =============================================================================
# Database Settings
# =============================================================================

DATABASE_URL = os.getenv("DATABASE_URL", "sqlite:///db.sqlite3")


# =============================================================================
# SessionFactory
# =============================================================================

@Component
class DatabaseConfig:
    """데이터베이스 설정 컴포넌트"""

    @Factory
    def session_factory(self) -> SessionFactory:
        """SessionFactory를 생성합니다.
        
        Returns:
            SessionFactory: 데이터베이스 세션 팩토리
        """
        return SessionFactory(DATABASE_URL)
