[project]
name = "{{project_name}}"
version = "0.1.0"
description = "A Bloom Framework application"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "bloom",
    "uvicorn[standard]",
]

[project.optional-dependencies]
dev = [
    "pytest",
    "pytest-asyncio",
]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
