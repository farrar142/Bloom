"""

import application  # 프로젝트 루트의 application.py
from bloom.tests import TestCase


class TestApplication(TestCase):
    """애플리케이션 테스트

    TestCase는 자동으로:
    - Application 인스턴스 생성 (self.app)
    - TestClient 생성 (self.client)
    - HTTP 메서드 래퍼 제공 (self.get(), self.post(), ...)
    """

    # 애플리케이션 모듈 스캔 (application.py의 application 객체 사용)
    components = [application]

    def test_app_ready(self):
        """Application이 정상적으로 초기화되는지 확인"""
        self.assertTrue(self.app._is_ready)

