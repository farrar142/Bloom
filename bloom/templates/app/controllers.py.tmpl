"""{{app_name}} Controllers

HTTP 엔드포인트를 정의합니다.
"""

from bloom import Controller, Get, Post, Put, Delete
from bloom.web import HttpRequest, HttpResponse

from .services import {{app_name_pascal}}Service
from .schemas import {{app_name_pascal}}Response


@Controller("/{{app_name}}")
class {{app_name_pascal}}Controller:
    """{{app_name_pascal}} API 컨트롤러"""

    service: {{app_name_pascal}}Service

    @Get("/")
    async def list(self, request: HttpRequest) -> HttpResponse:
        """목록 조회"""
        items = self.service.get_all()
        return HttpResponse.json({"items": items})

    @Get("/{id}")
    async def get(self, request: HttpRequest, id: int) -> HttpResponse:
        """단일 조회"""
        item = self.service.get_by_id(id)
        if item is None:
            return HttpResponse.json({"error": "Not found"}, status=404)
        return HttpResponse.json(item)

    @Post("/")
    async def create(self, request: HttpRequest) -> HttpResponse:
        """생성"""
        data = await request.json()
        item = self.service.create(data)
        return HttpResponse.json(item, status=201)

    @Put("/{id}")
    async def update(self, request: HttpRequest, id: int) -> HttpResponse:
        """수정"""
        data = await request.json()
        item = self.service.update(id, data)
        if item is None:
            return HttpResponse.json({"error": "Not found"}, status=404)
        return HttpResponse.json(item)

    @Delete("/{id}")
    async def delete(self, request: HttpRequest, id: int) -> HttpResponse:
        """삭제"""
        success = self.service.delete(id)
        if not success:
            return HttpResponse.json({"error": "Not found"}, status=404)
        return HttpResponse.json({"message": "Deleted"})
