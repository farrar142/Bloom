from typing import Any

from bloom import Component

# from bloom.db import SessionFactory


@Component
class {{app_name_pascal}}Repository:
    """{{app_name_pascal}} 레포지토리

    데이터베이스 접근을 담당합니다.
    실제 사용 시 SessionFactory를 주입받아 사용합니다.
    """

    # session_factory: SessionFactory  # DB 사용 시 주석 해제

    def __init__(self) -> None:
        # 임시 인메모리 저장소
        self._data: dict[int, dict[str, Any]] = {}
        self._next_id = 1

    def find_all(self) -> list[dict[str, Any]]:
        """전체 조회"""
        return list(self._data.values())

    def find_by_id(self, id: int) -> dict[str, Any] | None:
        """ID로 조회"""
        return self._data.get(id)

    def save(self, entity: dict[str, Any]) -> dict[str, Any]:
        """저장 (생성/수정)"""
        if "id" not in entity or entity["id"] is None:
            entity["id"] = self._next_id
            self._next_id += 1
        self._data[entity["id"]] = entity
        return entity

    def delete_by_id(self, id: int) -> bool:
        """ID로 삭제"""
        if id in self._data:
            del self._data[id]
            return True
        return False


