"""{{app_name}} Services

비즈니스 로직을 처리합니다.
"""

from typing import Any

from bloom import Component


@Component
class {{app_name_pascal}}Service:
    """{{app_name_pascal}} 서비스"""

    def __init__(self) -> None:
        # 임시 인메모리 저장소 (실제로는 Repository 사용)
        self._items: dict[int, dict[str, Any]] = {}
        self._next_id = 1

    def get_all(self) -> list[dict[str, Any]]:
        """전체 목록 조회"""
        return list(self._items.values())

    def get_by_id(self, id: int) -> dict[str, Any] | None:
        """ID로 조회"""
        return self._items.get(id)

    def create(self, data: dict[str, Any]) -> dict[str, Any]:
        """생성"""
        item = {"id": self._next_id, **data}
        self._items[self._next_id] = item
        self._next_id += 1
        return item

    def update(self, id: int, data: dict[str, Any]) -> dict[str, Any] | None:
        """수정"""
        if id not in self._items:
            return None
        self._items[id] = {"id": id, **data}
        return self._items[id]

    def delete(self, id: int) -> bool:
        """삭제"""
        if id not in self._items:
            return False
        del self._items[id]
        return True
