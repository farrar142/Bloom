"""{{app_name}} Services

비즈니스 로직을 처리합니다.
"""

from bloom import Component

from .entities import {{entity_name}}
from .repositories import {{entity_name}}Repository


@Component
class {{entity_name}}Service:
    """{{entity_name}} 서비스"""

    repository: {{entity_name}}Repository

    def get_all(self) -> list[{{entity_name}}]:
        """전체 목록 조회"""
        return self.repository.find_all()

    def get_by_id(self, id: int) -> {{entity_name}} | None:
        """ID로 조회"""
        return self.repository.find_by_id(id)

    def save(self, entity: {{entity_name}}) -> {{entity_name}}:
        """저장"""
        return self.repository.save(entity)

    def delete(self, id: int) -> bool:
        """삭제"""
        return self.repository.delete_by_id(id)
